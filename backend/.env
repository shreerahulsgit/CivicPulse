# ──────────────────────────────────────────────
# CivicPulse — Environment Configuration
# ──────────────────────────────────────────────

# Database
# Format: mysql+pymysql://<user>:<password>@<host>/<db_name>
DATABASE_URL=mysql+pymysql://root:1234567890@localhost/civicpulse

# App
APP_ENV=development
APP_DEBUG=True

# JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=civicpulse-change-this-to-a-random-64-char-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Cloudinary
# Get credentials from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=daww5putg
CLOUDINARY_API_KEY=428685715538299
CLOUDINARY_API_SECRET=4RycfEIuEbHieL5LlE6uRKcWchg

# AI Classification
# AI_MODEL_ENABLED: true = run model, false = always use manual category
AI_MODEL_ENABLED=false
# AI_MODEL_PATH: HuggingFace Hub model ID OR local directory path
# Default uses distilbert-base-uncased (architecture only, not yet fine-tuned)
AI_MODEL_PATH=distilbert-base-uncased
# AI_DEVICE: cpu | cuda | mps
AI_DEVICE=cpu

# Gemini AI (Google)
GEMINI_API_KEY=AQ.Ab8RN6IjnQ66Ve02nAARoL6D0hRenboi0ISYv_nAbaR9-RTxJw
GEMINI_ENABLED=true
GEMINI_MODEL=gemini-flash-lite-latest

# AI Duplicate Detection (Sentence-BERT)
# Shared AI_MODEL_ENABLED flag controls both classification and duplicate detection
SBERT_MODEL_NAME=all-MiniLM-L6-v2
SBERT_DEVICE=cpu

# Firebase Admin SDK
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Place the JSON file in the backend/ directory
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
